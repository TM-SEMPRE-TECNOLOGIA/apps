---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="TM Sempre Tecnologia — Em Breve"
  description="Engenharia e tecnologia que transformam operações reais."
>
  <!-- ─── Hero ─── -->
  <section class="hero" aria-label="Hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="badge" data-animate>
        <span class="badge-dot" aria-hidden="true"></span>
        Em desenvolvimento ativo
      </div>
      <h1 class="hero-title" data-animate>
        Engenharia que<br /><span>transforma</span>
      </h1>
      <p class="hero-subtitle" data-animate>
        Soluções de software e tecnologia para operações reais que precisam escalar.
      </p>
      <div class="hero-actions" data-animate>
        <a href="/blog" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
          Ler o Blog
        </a>
        <a href="#notify" class="btn btn-ghost">Receber atualizações</a>
      </div>
    </div>
    <div class="scroll-hint" aria-hidden="true">
      <span>scroll</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- ─── Main Content ─── -->
  <main class="main" id="main-content">

    <!-- Progress -->
    <div class="progress-wrap" data-animate>
      <div class="progress-header">
        <span class="prog-label">Progresso do lançamento</span>
        <span class="prog-pct" id="prog-pct">0%</span>
      </div>
      <div class="progress-track" role="progressbar" aria-valuenow="78" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar" id="progress-bar"></div>
      </div>
    </div>

    <!-- Notify Box -->
    <div class="notify-box" id="notify" data-animate>
      <div class="notify-inner">
        <h2 class="notify-title">Seja o primeiro a saber</h2>
        <p class="notify-desc">
          Cadastre-se para receber acesso antecipado, artigos técnicos e novidades
          da TM Sempre Tecnologia diretamente no seu e-mail.
        </p>

        <div id="notify-form-wrap">
          <form id="notify-form" class="form-row" novalidate>
            <div class="form-field">
              <label for="field-name">Nome</label>
              <input
                type="text"
                id="field-name"
                name="name"
                placeholder="Seu nome completo"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-field">
              <label for="field-email">E-mail</label>
              <input
                type="email"
                id="field-email"
                name="email"
                placeholder="seu@email.com"
                required
                autocomplete="email"
              />
            </div>
            <button type="submit" class="btn-submit" id="btn-submit">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              <span id="btn-label">Quero ser avisado</span>
            </button>
            <div class="notify-error" id="notify-error" role="alert" aria-live="polite"></div>
          </form>
        </div>

        <div class="notify-success" id="notify-success" role="alert" aria-live="polite">
          <div class="check-circle" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p><strong>Cadastro realizado!</strong><br />Você receberá novidades em primeira mão.</p>
        </div>
      </div>
    </div>

    <!-- Section: Pilares -->
    <p class="section-label" data-animate>Nossos pilares</p>
    <h2 class="section-title" data-animate>
      O que nos move<br /><span>a construir</span>
    </h2>

    <div class="pillars" role="list">
      <!-- Pilar 1 -->
      <article class="pillar" role="listitem" data-animate>
        <div class="pillar-num" aria-hidden="true">01</div>
        <div class="pillar-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3 class="pillar-title">Engenharia de Software</h3>
        <p class="pillar-desc">Código limpo, arquitetura sólida e sistemas que escalam com o crescimento do negócio.</p>
        <div class="pillar-divider" aria-hidden="true"></div>
        <ul class="pillar-list">
          <li>Desenvolvimento full-stack</li>
          <li>Arquitetura de microsserviços</li>
          <li>APIs robustas e documentadas</li>
        </ul>
        <span class="pillar-tag"><span class="pillar-tag-dot" aria-hidden="true"></span>Core</span>
      </article>

      <!-- Pilar 2 -->
      <article class="pillar" role="listitem" data-animate>
        <div class="pillar-num" aria-hidden="true">02</div>
        <div class="pillar-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3 class="pillar-title">Inteligência Aplicada</h3>
        <p class="pillar-desc">IA e automação integradas ao processo produtivo para gerar valor real e mensurável.</p>
        <div class="pillar-divider" aria-hidden="true"></div>
        <ul class="pillar-list">
          <li>Modelos de ML em produção</li>
          <li>Automação de processos</li>
          <li>Análise de dados em tempo real</li>
        </ul>
        <span class="pillar-tag"><span class="pillar-tag-dot" aria-hidden="true"></span>Inovação</span>
      </article>

      <!-- Pilar 3 -->
      <article class="pillar" role="listitem" data-animate>
        <div class="pillar-num" aria-hidden="true">03</div>
        <div class="pillar-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="pillar-title">Parceria Estratégica</h3>
        <p class="pillar-desc">Trabalhamos como extensão do seu time, com foco nos resultados que importam para o negócio.</p>
        <div class="pillar-divider" aria-hidden="true"></div>
        <ul class="pillar-list">
          <li>Consultoria técnica sênior</li>
          <li>Squads dedicados</li>
          <li>Revisão de arquitetura</li>
        </ul>
        <span class="pillar-tag"><span class="pillar-tag-dot" aria-hidden="true"></span>Equipe</span>
      </article>
    </div>

    <div class="sep" aria-hidden="true"></div>

    <!-- Contact Row -->
    <div class="contact-row" data-animate>
      <a href="mailto:contato@tmsempretecnologia.com.br" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        Falar com a equipe
      </a>
      <a href="/blog" class="btn btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        Ler artigos técnicos
      </a>
    </div>

  </main>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 64px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(232, 96, 16, 0.07) 0%, transparent 70%),
      linear-gradient(to bottom, transparent 60%, var(--bg) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 80px 32px;
    max-width: 760px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 18px;
    background: var(--acc);
    border: 1px solid var(--bro);
    border-radius: 100px;
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--o);
    margin-bottom: 40px;
    opacity: 0;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--o);
    box-shadow: 0 0 8px var(--o);
    animation: pls 2s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--fs);
    font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 24px;
    opacity: 0;
  }

  .hero-title span {
    color: var(--o);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 48px;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
  }

  /* Scroll Hint */
  .scroll-hint {
    position: absolute;
    bottom: 44px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
    opacity: 0;
    animation: fadeInUp 0.8s ease 1.5s forwards;
  }

  .scroll-hint span {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sub);
  }

  .scroll-arrow {
    width: 18px;
    height: 18px;
    border-right: 1.5px solid var(--o);
    border-bottom: 1.5px solid var(--o);
    transform: rotate(45deg);
    animation: arrowBounce 1.6s ease-in-out infinite;
  }

  @keyframes arrowBounce {
    0%, 100% { transform: rotate(45deg) translateY(0); opacity: 1; }
    50% { transform: rotate(45deg) translateY(5px); opacity: 0.5; }
  }

  /* ─── Main ─── */
  .main {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 96px 32px 112px;
  }

  /* Progress */
  .progress-wrap {
    width: 100%;
    max-width: 560px;
    margin-bottom: 72px;
    opacity: 0;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .prog-label {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sub);
  }

  .prog-pct {
    font-family: var(--fm);
    font-size: 13px;
    color: var(--o);
    font-weight: 500;
  }

  .progress-track {
    width: 100%;
    height: 2px;
    background: var(--brd);
    border-radius: 100px;
    overflow: hidden;
    position: relative;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--o), #ffb060);
    border-radius: 100px;
    transition: width 1.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .progress-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    animation: shimmer 2.4s ease-in-out infinite;
  }

  @keyframes shimmer {
    to { left: 120%; }
  }

  /* Notify Box */
  .notify-box {
    width: 100%;
    max-width: 560px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--radius);
    padding: 40px 36px;
    margin-bottom: 96px;
    position: relative;
    overflow: hidden;
    opacity: 0;
  }

  .notify-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--o), transparent);
    animation: scanline 3s ease-in-out infinite;
  }

  @keyframes scanline {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; box-shadow: 0 0 12px var(--o); }
  }

  .notify-inner {
    position: relative;
    z-index: 1;
  }

  .notify-title {
    font-family: var(--fs);
    font-weight: 600;
    font-size: 20px;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .notify-desc {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 28px;
    line-height: 1.65;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .form-field label {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sub);
  }

  .form-field input {
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: 6px;
    padding: 14px 16px;
    font-family: var(--ff);
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    width: 100%;
  }

  .form-field input::placeholder {
    color: var(--sub);
  }

  .form-field input:focus {
    border-color: var(--bro);
    box-shadow: 0 0 0 3px rgba(232, 96, 16, 0.08);
    transform: translateY(-1px);
  }

  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px;
    margin-top: 8px;
    background: var(--o);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-family: var(--ff);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.04em;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: background 0.2s, box-shadow 0.2s, transform 0.12s;
  }

  .btn-submit::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.4s ease;
  }

  .btn-submit:hover:not(:disabled) {
    background: var(--oh);
    box-shadow: 0 0 28px var(--og);
  }

  .btn-submit:hover:not(:disabled)::after {
    left: 140%;
  }

  .btn-submit:active:not(:disabled) {
    transform: scale(0.97);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-submit svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .notify-success {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 16px 0 8px;
    text-align: center;
  }

  .check-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(232, 96, 16, 0.1);
    border: 1px solid var(--bro);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .check-circle svg {
    width: 26px;
    height: 26px;
    color: var(--o);
  }

  .notify-success p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
  }

  .notify-success strong {
    color: var(--text);
  }

  .notify-error {
    display: none;
    padding: 12px 16px;
    background: rgba(163, 59, 42, 0.12);
    border: 1px solid rgba(163, 59, 42, 0.3);
    border-radius: 6px;
    margin-top: 14px;
    font-size: 14px;
    color: #e07060;
    text-align: center;
  }

  /* Section labels */
  .section-label {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--o);
    margin-bottom: 20px;
    opacity: 0;
  }

  .section-title {
    font-family: var(--fs);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--text);
    text-align: center;
    margin-bottom: 56px;
    opacity: 0;
    line-height: 1.2;
  }

  .section-title span {
    color: var(--o);
  }

  /* Pillars */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 960px;
    width: 100%;
    margin-bottom: 72px;
  }

  .pillar {
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--radius);
    padding: 26px 22px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    cursor: default;
    opacity: 0;
    transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
    will-change: transform;
  }

  .pillar::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    background: linear-gradient(135deg, var(--o), transparent 60%);
    opacity: 0;
    transition: opacity 0.35s;
    pointer-events: none;
  }

  .pillar:hover {
    border-color: var(--bro);
    background: var(--surf);
    box-shadow: 0 0 32px var(--og), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .pillar:hover::before {
    opacity: 0.06;
  }

  .pillar-num {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--o);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pillar-num::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--bro), transparent);
  }

  .pillar-icon {
    width: 46px;
    height: 46px;
    background: var(--acc);
    border: 1px solid var(--brd);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .pillar:hover .pillar-icon {
    border-color: var(--bro);
    box-shadow: 0 0 20px var(--og);
    transform: scale(1.08);
  }

  .pillar-icon svg {
    width: 22px;
    height: 22px;
    color: var(--o);
  }

  .pillar-title {
    font-family: var(--fs);
    font-weight: 600;
    font-size: 16px;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.25;
  }

  .pillar-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .pillar-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--bro), transparent);
    margin-bottom: 18px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }

  .pillar:hover .pillar-divider {
    transform: scaleX(1);
  }

  .pillar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .pillar-list li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 12px;
    color: var(--sub);
    line-height: 1.5;
    transition: color 0.25s;
  }

  .pillar:hover .pillar-list li {
    color: var(--muted);
  }

  .pillar-list li::before {
    content: '';
    width: 4px;
    height: 4px;
    min-width: 4px;
    border-radius: 50%;
    background: var(--o);
    margin-top: 5px;
    opacity: 0.6;
    transition: opacity 0.25s, transform 0.25s;
  }

  .pillar:hover .pillar-list li::before {
    opacity: 1;
    transform: scale(1.3);
  }

  .pillar-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    padding: 4px 10px;
    background: var(--acc);
    border: 1px solid var(--brd);
    border-radius: 100px;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sub);
    transition: border-color 0.3s, color 0.3s;
    align-self: flex-start;
  }

  .pillar:hover .pillar-tag {
    border-color: var(--bro);
    color: var(--o);
  }

  .pillar-tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--o);
  }

  /* Separator */
  .sep {
    width: 100%;
    max-width: 560px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--bro), transparent);
    margin-bottom: 64px;
  }

  /* Contact Row */
  .contact-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
  }

  /* Responsive */
  @media (max-width: 780px) {
    .pillars {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  @media (max-width: 580px) {
    .hero-actions,
    .contact-row {
      flex-direction: column;
      align-items: stretch;
    }

    .btn, .btn-primary, .btn-ghost {
      justify-content: center;
    }

    .notify-box {
      padding: 24px 18px;
    }
  }
</style>

<script>
  // ─── Progress bar animation ───
  const bar = document.getElementById('progress-bar') as HTMLElement | null;
  const pct = document.getElementById('prog-pct');
  const TARGET = 78;

  if (bar && pct) {
    setTimeout(() => {
      bar.style.width = `${TARGET}%`;
      let current = 0;
      const step = () => {
        current = Math.min(current + 1, TARGET);
        pct.textContent = `${current}%`;
        if (current < TARGET) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }, 600);
  }

  // ─── Hero elements — staggered fade-in ───
  const heroEls = document.querySelectorAll<HTMLElement>('.hero-content [data-animate]');
  heroEls.forEach((el, i) => {
    el.style.animationDelay = `${i * 0.18 + 0.2}s`;
    el.style.animation = `fadeInUp 0.7s ease ${i * 0.18 + 0.2}s forwards`;
  });

  // ─── Scroll-triggered elements ───
  const scrollEls = document.querySelectorAll<HTMLElement>('.main [data-animate]');
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, idx) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.animation = `fadeInUp 0.6s ease ${idx * 0.08}s forwards`;
          obs.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  scrollEls.forEach((el) => obs.observe(el));

  // ─── Form logic ───
  const form = document.getElementById('notify-form') as HTMLFormElement | null;
  const successEl = document.getElementById('notify-success');
  const errorEl = document.getElementById('notify-error');
  const submitBtn = document.getElementById('btn-submit') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('btn-label');

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorEl) errorEl.style.display = 'none';

      const nameInput = form.querySelector<HTMLInputElement>('#field-name');
      const emailInput = form.querySelector<HTMLInputElement>('#field-email');

      if (!nameInput?.value.trim() || !emailInput?.value.trim()) {
        if (errorEl) {
          errorEl.textContent = 'Por favor, preencha todos os campos.';
          errorEl.style.display = 'block';
        }
        return;
      }

      submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = 'Enviando...';

      // Simulate API call (replace with real endpoint)
      await new Promise((r) => setTimeout(r, 1400));

      const formWrap = document.getElementById('notify-form-wrap');
      if (formWrap) formWrap.style.display = 'none';
      if (successEl) successEl.style.display = 'flex';
    });
  }
</script>
